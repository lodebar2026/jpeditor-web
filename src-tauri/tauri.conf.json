{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jpeditor",
  "version": "0.5.0",
  "identifier": "co.endao.jpeditor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "简谱编辑器",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null,
      "headers": {
        "Cross-Origin-Opener-Policy": "same-origin",
        "Cross-Origin-Embedder-Policy": "require-corp"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../public/redist/Bravura.otf": "Bravura.otf",
      "../public/redist/ocr/ch_PP-OCRv6_small_rec_infer.onnx": "ocr/rec.onnx",
      "../public/redist/ocr/ch_PP-OCRv4_det_infer.onnx": "ocr/det.onnx"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
